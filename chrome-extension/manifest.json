{
  "manifest_version": 3,
  "name": "Nexaviq Agent Co-Pilot",
  "version": "1.0.0",
  "description": "Real-time compliance checklist and agent assistant for Genesys, Twilio, and web-based BPO dialers.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Nexaviq Co-Pilot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
